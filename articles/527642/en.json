  "body_skeleton": "<h1 id=\"h_3600ed6557\">@@body:0001@@</h1><p class=\"no-margin\">@@body:0002@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_01d0421205\">@@body:0003@@</h1><h2 id=\"h_db96ebb074\">@@body:0004@@</h2><ul><li><p class=\"no-margin\">@@body:0005@@</p></li><li><p class=\"no-margin\">@@body:0006@@</p></li><li><p class=\"no-margin\">@@body:0007@@</p></li></ul><h2 id=\"h_0c0c70f401\">@@body:0008@@</h2><ul><li><p class=\"no-margin\">@@body:0009@@</p></li><li><p class=\"no-margin\">@@body:0010@@</p></li><li><p class=\"no-margin\">@@body:0011@@</p></li></ul><h1 id=\"h_1c894e83e4\">@@body:0012@@</h1><p class=\"no-margin\">@@body:0013@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0014@@</p><ul><li><p class=\"no-margin\">@@body:0015@@</p></li><li><p class=\"no-margin\">@@body:0016@@</p></li><li><p class=\"no-margin\">@@body:0017@@</p></li><li><p class=\"no-margin\">@@body:0018@@</p></li><li><p class=\"no-margin\">@@body:0019@@</p></li><li><p class=\"no-margin\">@@body:0020@@</p></li><li><p class=\"no-margin\">@@body:0021@@</p></li></ul><p class=\"no-margin\">@@body:0022@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_8b5549aae0\">@@body:0023@@</h1><p class=\"no-margin\">@@body:0024@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0025@@</p><ul><li><p class=\"no-margin\">@@body:0026@@</p></li><li><p class=\"no-margin\">@@body:0027@@</p></li><li><p class=\"no-margin\">@@body:0028@@</p></li><li><p class=\"no-margin\">@@body:0029@@</p></li><li><p class=\"no-margin\">@@body:0030@@</p></li><li><p class=\"no-margin\">@@body:0031@@</p></li><li><p class=\"no-margin\">@@body:0032@@</p></li><li><p class=\"no-margin\">@@body:0033@@</p></li></ul><p class=\"no-margin\">@@body:0034@@</p><ul><li><p class=\"no-margin\">@@body:0035@@</p></li><li><p class=\"no-margin\">@@body:0036@@</p></li></ul><p class=\"no-margin\"></p>\n<h1 id=\"h_e8d9f53fda\">@@body:0037@@</h1><p class=\"no-margin\">@@body:0038@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0039@@</p><ul><li><p class=\"no-margin\">@@body:0040@@</p></li><li><p class=\"no-margin\">@@body:0041@@</p></li><li><p class=\"no-margin\">@@body:0042@@</p></li><li><p class=\"no-margin\">@@body:0043@@</p></li><li><p class=\"no-margin\">@@body:0044@@</p></li></ul><p class=\"no-margin\">@@body:0045@@</p><ul><li><p class=\"no-margin\">@@body:0046@@</p></li><li><p class=\"no-margin\">@@body:0047@@</p></li></ul><h1 id=\"h_6f5799867e\">@@body:0048@@</h1><p class=\"no-margin\"></p>\n<h2 id=\"h_efc97fe532\">@@body:0049@@</h2><p class=\"no-margin\">@@body:0050@@</p><ul><li><p class=\"no-margin\">@@body:0051@@</p></li><li><p class=\"no-margin\">@@body:0052@@</p></li><li><p class=\"no-margin\">@@body:0053@@</p></li><li><p class=\"no-margin\">@@body:0054@@</p></li></ul><div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90374091/affcdc80c31298f4f575641fae50/upload_7758092349318288509.png?expires=1781805600&amp;signature=4226bb600c5a7a9c4a8ac6ebaa9ff9d1b17b494e0c4bbb391373b279331302d6&amp;req=2dVswlz6pTZk2hj99dpg6loX7qW0TGYAE03yws5W0FiOrpUM04MFAA6cjWwK%0AmtGh0iC8w7%2Br%2B0u1b5slGifu%0A\"/></div><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0055@@</p><ol><li><p class=\"no-margin\">@@body:0056@@</p></li><li><p class=\"no-margin\">@@body:0057@@</p></li><li><p class=\"no-margin\">@@body:0058@@</p></li></ol><div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90374102/d53ef3c2f1e8d347f1e8ff7893d9/upload_10241621738455343578.png?expires=1781805600&amp;signature=9312cae2aab42c47cc6169d322083354bfff3303d142df3ad07ca78366ac7fad&amp;req=2dVswlz7rDVk2hj99dpg6m7JQ5TPCeqTtfue57H4sk9GA4vUAaSp0anOlkB6%0AJxHsBsZfzs8KqoZHDeoyFtEs%0A\"/></div><p class=\"no-margin\"></p>\n<h2 id=\"h_6ea57e823e\">@@body:0059@@</h2><ol><li><p class=\"no-margin\">@@body:0060@@</p></li><li><p class=\"no-margin\">@@body:0061@@</p></li><li><p class=\"no-margin\">@@body:0062@@</p></li></ol><div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90374118/6df2f5fc89dbbf3bb7879fc6c79e/upload_14287163150851909334.png?expires=1781805600&amp;signature=fac8313ee32ce8022c384286a698a7fb7c359da10b8bc2ffb760a04b72013556&amp;req=2dVswlz7rT9k2hj99dpg6sLQ1%2FeNXIRGQFTzWJpNlPnlRKEBa%2FNHScJxaMup%0AtnIOH5wsqV0QEUjBkiwD6QSG%0A\"/></div><p class=\"no-margin\"></p>\n<h2 id=\"h_aee565764a\">@@body:0063@@</h2><ol><li><p class=\"no-margin\">@@body:0064@@</p></li><li><p class=\"no-margin\">@@body:0065@@</p></li><li><p class=\"no-margin\">@@body:0066@@</p></li><li><p class=\"no-margin\">@@body:0067@@</p></li><li><p class=\"no-margin\">@@body:0068@@</p><ol><li><p class=\"no-margin\">@@body:0069@@</p></li><li><p class=\"no-margin\">@@body:0070@@</p></li><li><p class=\"no-margin\">@@body:0071@@</p></li></ol></li></ol><h2 id=\"h_415f554ed6\">@@body:0072@@</h2><ol><li><p class=\"no-margin\">@@body:0073@@</p></li><li><p class=\"no-margin\">@@body:0074@@</p></li><li><p class=\"no-margin\">@@body:0075@@</p></li><li><p class=\"no-margin\">@@body:0076@@</p></li></ol>",
  "segments": {
    "title": {
      "field": "title",
      "text": "Different roles and permissions on the platform",
      "hash": "57d03bf5eb4c"
    },
    "description": {
      "field": "description",
      "text": "Learn more about roles and permissions on the platform",
      "hash": "8c52cd2c9e49"
    },
    "body:0001": {
      "field": "body",
      "text": "What are roles and permissions?",
      "hash": "714d08d4bd8d"
    },
    "body:0002": {
      "field": "body",
      "text": "Roles define what users are allowed to do, from simply visiting the platform to managing complex multi-project structures. Assigning the right roles ensures responsibilities are distributed efficiently, data privacy is respected, and users only access what they need.",
      "hash": "2b1a471446f6"
    },
    "body:0003": {
      "field": "body",
      "text": "What are the different roles on the platform?",
      "hash": "646e5da02481"
    },
    "body:0004": {
      "field": "body",
      "text": "End-user roles:",
      "hash": "7a188fa3e7d7"
    },
    "body:0005": {
      "field": "body",
      "text": "<b>Visitor</b>: Anyone who visits the platform without registering",
      "hash": "6817a07a6187"
    },
    "body:0006": {
      "field": "body",
      "text": "<b>User</b>: Someone who has registered but hasn't interacted yet",
      "hash": "627c8345ff18"
    },
    "body:0007": {
      "field": "body",
      "text": "<b>Participant</b>: A registered user who has taken action (posted input, commented, voted, etc.)",
      "hash": "9838039ec1cf"
    },
    "body:0008": {
      "field": "body",
      "text": "Platform management roles:",
      "hash": "131d89de6137"
    },
    "body:0009": {
      "field": "body",
      "text": "<b>Project Manager</b>: Manages a (or more) specific project(s)",
      "hash": "d69de4a96742"
    },
    "body:0010": {
      "field": "body",
      "text": "<b>Folder Manager</b>: Manages a folder and its projects",
      "hash": "760ee652d7a6"
    },
    "body:0011": {
      "field": "body",
      "text": "<b>Platform Admin</b>: Has access to the entire admin panel and platform-level tools",
      "hash": "b60eee998197"
    },
    "body:0012": {
      "field": "body",
      "text": "What can platform admins do?",
      "hash": "bd32e3895369"
    },
    "body:0013": {
      "field": "body",
      "text": "Admins are the highest-level users who manage the entire platform.",
      "hash": "1a4361e862c7"
    },
    "body:0014": {
      "field": "body",
      "text": "<b>Admin capabilities:</b>",
      "hash": "a2f6a2bb923e"
    },
    "body:0015": {
      "field": "body",
      "text": "Create, approve, and publish projects.",
      "hash": "d78722aaffa8"
    },
    "body:0016": {
      "field": "body",
      "text": "Assign project or folder managers.",
      "hash": "dfe4d607940a"
    },
    "body:0017": {
      "field": "body",
      "text": "Access the Users tab, smart groups, and user data.",
      "hash": "853685d817fb"
    },
    "body:0018": {
      "field": "body",
      "text": "Manage platform branding and homepage.",
      "hash": "b4e5452b0d27"
    },
    "body:0019": {
      "field": "body",
      "text": "Send messages using platform-wide email tools.",
      "hash": "9ce949a67855"
    },
    "body:0020": {
      "field": "body",
      "text": "View full dashboard and analytics tools.",
      "hash": "6c59c572fafc"
    },
    "body:0021": {
      "field": "body",
      "text": "Post content using a general admin profile.",
      "hash": "4ac28ae5831c"
    },
    "body:0022": {
      "field": "body",
      "text": "Admins are the only users who can grant admin rights or assign others to manage folders or projects.",
      "hash": "e412ca032a84"
    },
    "body:0023": {
      "field": "body",
      "text": "What can project managers do?",
      "hash": "9f3b5a0388a8"
    },
    "body:0024": {
      "field": "body",
      "text": "Project managers handle individual projects and participant engagement.",
      "hash": "e3658df24524"
    },
    "body:0025": {
      "field": "body",
      "text": "<b>Project manager capabilities:</b>",
      "hash": "106d382389fb"
    },
    "body:0026": {
      "field": "body",
      "text": "Edit project title, description, and access rights",
      "hash": "6c919c64af35"
    },
    "body:0027": {
      "field": "body",
      "text": "View participation metrics and demographic breakdowns",
      "hash": "b8eff8f16ae6"
    },
    "body:0028": {
      "field": "body",
      "text": "Respond to input and send emails to project participants",
      "hash": "aa30bf2052a9"
    },
    "body:0029": {
      "field": "body",
      "text": "Add events and export attendee lists",
      "hash": "88b3f810a31f"
    },
    "body:0030": {
      "field": "body",
      "text": "Track participation and traffic sources",
      "hash": "a324b872b986"
    },
    "body:0031": {
      "field": "body",
      "text": "Access user data for their project (excluding votes with personal identifiers)",
      "hash": "6881f42a111c"
    },
    "body:0032": {
      "field": "body",
      "text": "Send project-specific emails using either their name or a generic platform name",
      "hash": "d97c26e10d05"
    },
    "body:0033": {
      "field": "body",
      "text": "Use testing features (e.g., multiple survey submissions or participation during closed phases)",
      "hash": "4172b96603c2"
    },
    "body:0034": {
      "field": "body",
      "text": "<b>Limitations:</b>",
      "hash": "af1b0e97da34"
    },
    "body:0035": {
      "field": "body",
      "text": "Cannot create new registration questions or invite other project managers",
      "hash": "be11e435d7a0"
    },
    "body:0036": {
      "field": "body",
      "text": "Cannot email users outside their assigned projects",
      "hash": "8010d50a025a"
    },
    "body:0037": {
      "field": "body",
      "text": "What can folder managers do?",
      "hash": "83e2a76886bb"
    },
    "body:0038": {
      "field": "body",
      "text": "Folder managers oversee a group of projects and assist in organization-wide coordination.",
      "hash": "01b8ddd590ea"
    },
    "body:0039": {
      "field": "body",
      "text": "<b>Folder manager capabilities:</b>",
      "hash": "e98a8f5798f5"
    },
    "body:0040": {
      "field": "body",
      "text": "Modify folder description and settings",
      "hash": "d87632121b97"
    },
    "body:0041": {
      "field": "body",
      "text": "Create projects within their folder",
      "hash": "d4a985ee66e0"
    },
    "body:0042": {
      "field": "body",
      "text": "Automatically become project manager for projects they create",
      "hash": "853320000687"
    },
    "body:0043": {
      "field": "body",
      "text": "Publish and approve projects in their folder",
      "hash": "77c7118648d5"
    },
    "body:0044": {
      "field": "body",
      "text": "Set unused projects to draft (instead of deleting)",
      "hash": "79d9cb6a4b11"
    },
    "body:0045": {
      "field": "body",
      "text": "<b>Limitations:</b>",
      "hash": "af1b0e97da34"
    },
    "body:0046": {
      "field": "body",
      "text": "Cannot delete projects",
      "hash": "42e43a04d49f"
    },
    "body:0047": {
      "field": "body",
      "text": "Cannot create platform-wide changes",
      "hash": "58fad3f3960f"
    },
    "body:0048": {
      "field": "body",
      "text": "How to assign/remove a role?",
      "hash": "33fd8eabba8a"
    },
    "body:0049": {
      "field": "body",
      "text": "How to assign a project manager:",
      "hash": "85649ca4dea6"
    },
    "body:0050": {
      "field": "body",
      "text": "1. Through the user list if you are an admin:",
      "hash": "b8e4e8f0e77b"
    },
    "body:0051": {
      "field": "body",
      "text": "Go to the <b>Users</b> tab",
      "hash": "de7bca150d14"
    },
    "body:0052": {
      "field": "body",
      "text": "select the 3 dots on the far right side of the person's name",
      "hash": "4b768b6da5eb"
    },
    "body:0053": {
      "field": "body",
      "text": "select <b>Set as Project Manager</b>",
      "hash": "deb2d2d96795"
    },
    "body:0054": {
      "field": "body",
      "text": "a window will appear to select the project to assign to this new Project Manager",
      "hash": "03f690bb8329"
    },
    "body:0055": {
      "field": "body",
      "text": "2. through the project management rights",
      "hash": "324b0a426230"
    },
    "body:0056": {
      "field": "body",
      "text": "Navigate to the project.",
      "hash": "ce842b33b934"
    },
    "body:0057": {
      "field": "body",
      "text": "Go to <b>General </b>tab<b> &gt; Access Rights</b>.",
      "hash": "53c9f82968bb"
    },
    "body:0058": {
      "field": "body",
      "text": "Under <b>Project Management</b>, add the user's name.",
      "hash": "0efb2a322705"
    },
    "body:0059": {
      "field": "body",
      "text": "How to assign a folder manager:",
      "hash": "1695ce760e64"
    },
    "body:0060": {
      "field": "body",
      "text": "Navigate to the folder.",
      "hash": "d71b491e5025"
    },
    "body:0061": {
      "field": "body",
      "text": "Open the <b>Permissions tab</b>.",
      "hash": "8f1f6dec47fe"
    },
    "body:0062": {
      "field": "body",
      "text": "Add the user under <b>Folder Management</b>.",
      "hash": "9bbfc48f3894"
    },
    "body:0063": {
      "field": "body",
      "text": "How to assign a platform admin:",
      "hash": "5160af510139"
    },
    "body:0064": {
      "field": "body",
      "text": "Choose a shared email address (e.g. <a class=\"intercom-content-link\" href=\"mailto:participation@cityname.com\" target=\"_blank\"><code>participation@cityname.com</code></a>).",
      "hash": "245fd2ed1799"
    },
    "body:0065": {
      "field": "body",
      "text": "Register it as a user.",
      "hash": "95e9a90a813d"
    },
    "body:0066": {
      "field": "body",
      "text": "Enter a clear and recognizable name like <code>Moderator [City]</code> or <code>City of Springfield</code>.",
      "hash": "7000f8150b50"
    },
    "body:0067": {
      "field": "body",
      "text": "Set a profile picture if desired.",
      "hash": "3c057b8466b4"
    },
    "body:0068": {
      "field": "body",
      "text": "Log in through another Admin account",
      "hash": "0773ecaedb8f"
    },
    "body:0069": {
      "field": "body",
      "text": "Go to the <b>Users</b> tab",
      "hash": "de7bca150d14"
    },
    "body:0070": {
      "field": "body",
      "text": "select the 3 dots on the far right side of the users's name",
      "hash": "57007763ff62"
    },
    "body:0071": {
      "field": "body",
      "text": "select <b>Set as Admin</b>",
      "hash": "b6b9db3c7e70"
    },
    "body:0072": {
      "field": "body",
      "text": "Remove rights from a user",
      "hash": "d2466df50754"
    },
    "body:0073": {
      "field": "body",
      "text": "Navigate to the users tab",
      "hash": "f11e3fd4b156"
    },
    "body:0074": {
      "field": "body",
      "text": "Find the user",
      "hash": "01eb70ef7230"
    },
    "body:0075": {
      "field": "body",
      "text": "Click on the 3 dots at the right side",
      "hash": "51b7806ab74a"
    },
    "body:0076": {
      "field": "body",
      "text": "Select ‘Set as normal user’",
      "hash": "a7fed9bca29a"
    }
  }
}