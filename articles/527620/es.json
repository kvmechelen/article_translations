    },
    "body:0064": {
      "field": "body",
      "source": "For other data that cannot be easily downloaded from the platform, you are able to use our public API to pull all types of data from the platform and use it for external data analysis. For example to download things like a master list of all projects on the platform (like project names, dates, status) with the API you can easily pull such a list.",
      "source_hash": "956da72109dd",
      "target": "For other data that cannot be easily downloaded from the platform, you are able to use our public API to pull all types of data from the platform and use it for external data analysis. For example to download things like a master list of all projects on the platform (like project names, dates, status) with the API you can easily pull such a list.",
      "translated_from_hash": "956da72109dd",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0065": {
      "field": "body",
      "source": "All API documentation can be found here: <a class=\"intercom-content-link\" href=\"https://developers.govocal.com/api/\" target=\"_blank\">https://developers.govocal.com/api/</a>. There you can see all the information that you can pull with the API. For example for projects you can see all the data attributes that you can pull:",
      "source_hash": "c94eaf75708f",
      "target": "All API documentation can be found here: <a class=\"intercom-content-link\" href=\"https://developers.govocal.com/api/\" target=\"_blank\">https://developers.govocal.com/api/</a>. There you can see all the information that you can pull with the API. For example for projects you can see all the data attributes that you can pull:",
      "translated_from_hash": "c94eaf75708f",
      "origin": "machine",
      "status": "unverified"
    },
