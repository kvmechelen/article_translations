      "hash": "db0886ee9418"
    },
    "body:0021": {
      "field": "body",
      "text": "Image: Project banner image",
      "hash": "6d0d7a3fbd70"
    },
    "body:0022": {
      "field": "body",
      "text": "Ideas overview",
      "hash": "c78faa0eefc3"
    },
    "body:0023": {
      "field": "body",
      "text": "Title: <i>All Ideas • [Organization Name]</i>",
      "hash": "96c8ee191fc4"
    },
    "body:0024": {
      "field": "body",
      "text": "Description: <i>Explore all ideas posted...</i>",
      "hash": "93c80221fcbf"
    },
    "body:0025": {
      "field": "body",
      "text": "Individual idea",
      "hash": "3d74f8dd497c"
    },
    "body:0026": {
      "field": "body",
      "text": "Title: <i>Idea • [Idea Title]</i>",
      "hash": "a12999b0716a"
    },
    "body:0027": {
      "field": "body",
      "text": "If shared by author: <i>Support my idea: [Idea Title]</i>",
      "hash": "efc43e8e49a7"
    },
    "body:0028": {
      "field": "body",
      "text": "Image: User-uploaded image",
      "hash": "2fcdd983ba91"
    },
    "body:0029": {
      "field": "body",
      "text": "These defaults update dynamically based on the page being viewed to optimize discoverability.",
      "hash": "844f37e5559f"
    },
    "body:0030": {
      "field": "body",
      "text": "Tips on how to improve search engine ranking",
      "hash": "8d34329edc42"
    },
    "body:0031": {
      "field": "body",
      "text": "Search engines use many factors to rank pages, but two areas you can influence are metadata and content popularity.",
      "hash": "46f0867e7644"
    },
    "body:0032": {
      "field": "body",
      "text": "Metadata tips:",
      "hash": "608eff47e1f8"
    },
    "body:0033": {
      "field": "body",
      "text": "Use clear, descriptive titles and descriptions",
      "hash": "17aef515f936"
    },
    "body:0034": {
      "field": "body",
      "text": "Include relevant keywords (e.g. city name, voting, participation)",
      "hash": "c31b737120a1"
    },
    "body:0035": {
      "field": "body",
      "text": "Content popularity tips:",
      "hash": "57f80a79fb54"
    },
    "body:0036": {
      "field": "body",
      "text": "Publish content regularly (e.g. ideas, updates, events)",
      "hash": "cd3c3266248c"
    },
    "body:0037": {
      "field": "body",
      "text": "Share links on reliable channels (e.g. newsletters, social media)",
      "hash": "b6197c06aed3"
    },
    "body:0038": {
      "field": "body",
      "text": "Encourage backlinking from official websites",
      "hash": "828f1db6aa1c"
    },
    "body:0039": {
      "field": "body",
      "text": "Avoid spamming, quality matters more than quantity.",
      "hash": "11537fcf1037"
    },
    "body:0040": {
      "field": "body",
      "text": "How to customize your platforms metadata?",
      "hash": "a3a960a4e65d"
    },
    "body:0041": {
      "field": "body",
      "text": "<b>Steps:</b>",
      "hash": "79ea6cc10451"
    },
    "body:0042": {
      "field": "body",
      "text": "Identify which page(s) you want to update (e.g., homepage, a project, idea page).",
      "hash": "60cfe3ce6a0c"
    },
    "body:0043": {
      "field": "body",
      "text": "Prepare the new metadata:",
      "hash": "0207017e7c79"
    },
    "body:0044": {
      "field": "body",
      "text": "Title",
      "hash": "7e8cd2056da7"
    },
    "body:0045": {
      "field": "body",
      "text": "Description",
      "hash": "526e0087cc3f"
    },
    "body:0046": {
      "field": "body",
      "text": "Optional preview image (where applicable)",
      "hash": "a91858b2afb0"
    },
    "body:0047": {
      "field": "body",
      "text": "Open the chat bubble on the bottom right of your platform.",
      "hash": "01404005d12e"
    },
    "body:0048": {
      "field": "body",
      "text": "Contact the Go Vocal support team and provide the new metadata.",
      "hash": "a849202ec972"
    },
    "body:0049": {
      "field": "body",
      "text": "They will update the tags on your behalf.",
      "hash": "71c2965eef81"
    }
  }
}