      "hash": "5c51ec2a8667"
    },
    "body:0017": {
      "field": "body",
      "text": "Description: <i>Explore all ongoing projects...</i>",
      "hash": "9d0ad158c3d6"
    },
    "body:0018": {
      "field": "body",
      "text": "Image: Platform header image",
      "hash": "4189241029d3"
    },
    "body:0019": {
      "field": "body",
      "text": "Individual project page",
      "hash": "710f36414d1d"
    },
    "body:0020": {
      "field": "body",
