  "body_skeleton": "<h1 id=\"h_38f0dcc468\">@@body:0001@@</h1><p class=\"no-margin\">@@body:0002@@</p><ul><li><p class=\"no-margin\">@@body:0003@@</p></li><li><p class=\"no-margin\">@@body:0004@@</p></li><li><p class=\"no-margin\">@@body:0005@@</p></li></ul><p class=\"no-margin\"></p>\n<div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90373888/6e4b9093bcd822d06ad567b42c93/image.png-expires%3D1768395600-req%3DdSgmEs19noJZWvMW1HO4zW-2Fq9cOM-2FVsiA21VZsAXn9rpkRh0qvMNugkkk02W-0Av1Wb-0A-signature%3D97216fe8988cad2a9c2dc590bae2c18a9141f257b863ec253ac887f552aab629?expires=1781870400&amp;signature=ed8412bf68c3f996d7a78b9c50dea6fb4b47e302bed479d554468569cff67245&amp;req=2dVswlvypD9k2hj99dpg6n5QdITbOVSntEQiF7fCFXoo1RNXF%2BgXOw7JE%2BXI%0Az%2FAqgSydB%2FJgWpt9j6cL6zgj%0A\"/></div><p class=\"no-margin\"></p>\n<h1 id=\"h_5f695739b3\">@@body:0006@@</h1><p class=\"no-margin\">@@body:0007@@</p><p class=\"no-margin\"></p>\n<h2 id=\"h_781e4ea1dd\">@@body:0008@@</h2><ul><li><p class=\"no-margin\">@@body:0009@@</p></li><li><p class=\"no-margin\">@@body:0010@@</p></li><li><p class=\"no-margin\">@@body:0011@@</p></li></ul><h2 id=\"h_69a893828b\">@@body:0012@@</h2><ul><li><p class=\"no-margin\">@@body:0013@@</p></li><li><p class=\"no-margin\">@@body:0014@@</p></li><li><p class=\"no-margin\">@@body:0015@@</p></li></ul><h2 id=\"h_3474a91643\">@@body:0016@@</h2><ul><li><p class=\"no-margin\">@@body:0017@@</p></li><li><p class=\"no-margin\">@@body:0018@@</p><ul><li><p class=\"no-margin\">@@body:0019@@</p></li><li><p class=\"no-margin\">@@body:0020@@</p><div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90373897/5a9961de1d33ad40b95cc729e286/image-1.png-expires%3D1768395600-req%3DdSgnFsp4m4ZXX-2FMW1HO4zTYfP5aYAp7I5ggtWqDhIm5gdOb-2BICsOkrRvfASg-0A6YXF-0A-signature%3D179e9aabdb0a836753cfc4f5ac5d1d4efbcc5ef55b6cd353a88511e22c07b688?expires=1781870400&amp;signature=faf9ea4d4eae61ed1ba847204a3f10af