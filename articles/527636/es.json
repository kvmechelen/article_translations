    "body:0001": {
      "field": "body",
      "source": "What are online workshops?",
      "source_hash": "bfb49a4c88f9",
      "target": "What are online workshops?",
      "translated_from_hash": "bfb49a4c88f9",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0002": {
      "field": "body",
      "source": "The Online Workshop feature enables admins to host live, interactive sessions on the platform, including breakout groups, polls, Q&amp;A, and real-time collaboration.",
      "source_hash": "8bbbfac95dc3",
      "target": "The Online Workshop feature enables admins to host live, interactive sessions on the platform, including breakout groups, polls, Q&amp;A, and real-time collaboration.",
      "translated_from_hash": "8bbbfac95dc3",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0003": {
      "field": "body",
      "source": "Supports up to 50 participants",
      "source_hash": "70ee9b91c2ff",
      "target": "Supports up to 50 participants",
      "translated_from_hash": "70ee9b91c2ff",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0004": {
      "field": "body",
      "source": "Works on desktop only (Chrome, Firefox, Edge)",
      "source_hash": "931efc04004b",
      "target": "Works on desktop only (Chrome, Firefox, Edge)",
      "translated_from_hash": "931efc04004b",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0005": {
      "field": "body",
      "source": "Allows for multi-step agendas and data exports",
      "source_hash": "b369240cdd08",
      "target": "Allows for multi-step agendas and data exports",
      "translated_from_hash": "b369240cdd08",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0006": {
      "field": "body",
      "source": "What are the different room steps?",
      "source_hash": "9d5f0cd1d74f",
      "target": "What are the different room steps?",
      "translated_from_hash": "9d5f0cd1d74f",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0007": {
      "field": "body",
      "source": "Workshops support several participation methods within each room-step. Each method determines how participants interact in that step and what appears on the right side of the screen (the video feed always remains on the left).",
      "source_hash": "bd7eeca3f649",
      "target": "Workshops support several participation methods within each room-step. Each method determines how participants interact in that step and what appears on the right side of the screen (the video feed always remains on the left).",
      "translated_from_hash": "bd7eeca3f649",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0008": {
      "field": "body",
      "source": "Q&amp;A",
      "source_hash": "b8b61fa19ebb",
      "target": "Q&amp;A",
      "translated_from_hash": "b8b61fa19ebb",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0009": {
      "field": "body",
      "source": "Allows admins to ask questions and participants to post answers (up to 255 characters) or vote on others’ responses",
      "source_hash": "770b7a3762cd",
      "target": "Allows admins to ask questions and participants to post answers (up to 255 characters) or vote on others’ responses",
