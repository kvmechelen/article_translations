    "body:0011": {
      "field": "body",
      "source": "What are user groups?",
      "source_hash": "b8975310abc6",
      "target": "What are user groups?",
      "translated_from_hash": "b8975310abc6",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0012": {
      "field": "body",
      "source": "A user group is a collection of users that are grouped together based on shared characteristics or can be manually defined. These groups can be used to control access and target communication efficiently.",
      "source_hash": "fc818b6706d1",
      "target": "A user group is a collection of users that are grouped together based on shared characteristics or can be manually defined. These groups can be used to control access and target communication efficiently.",
      "translated_from_hash": "fc818b6706d1",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0013": {
      "field": "body",
      "source": "User groups allow you to organize participants for targeted communication and to manage viewing or participation rights on projects.",
      "source_hash": "b181bf39e0db",
      "target": "User groups allow you to organize participants for targeted communication and to manage viewing or participation rights on projects.",
      "translated_from_hash": "b181bf39e0db",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0014": {
      "field": "body",
      "source": "There are two types:",
      "source_hash": "f79fbdcef94d",
      "target": "There are two types:",
      "translated_from_hash": "f79fbdcef94d",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0015": {
      "field": "body",
      "source": "<b>Manual Groups:</b> You add users manually",
      "source_hash": "765863cff7ca",
      "target": "<b>Manual Groups:</b> You add users manually",
      "translated_from_hash": "765863cff7ca",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0016": {
      "field": "body",
      "source": "<b>Smart Groups:</b> Users are automatically added when they meet set conditions (e.g., lives in a certain neighborhood, age, profession)",
      "source_hash": "1e7422586df1",
      "target": "<b>Smart Groups:</b> Users are automatically added when they meet set conditions (e.g., lives in a certain neighborhood, age, profession)",
      "translated_from_hash": "1e7422586df1",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0017": {
      "field": "body",
      "source": "Smart Groups are indicated by ⚡️ in the Users tab.",
      "source_hash": "0b61e67068a1",
      "target": "Smart Groups are indicated by ⚡️ in the Users tab.",
      "translated_from_hash": "0b61e67068a1",
      "origin": "machine",
      "status": "unverified"
    },
    "body:0018": {
      "field": "body",
      "source": "ℹ️ Note: Since smart groups are set with specific conditions, it is not possible to manually add/remove users from this group",
      "source_hash": "15776d7f05fb",
      "target": "ℹ️ Note: Since smart groups are set with specific conditions, it is not possible to manually add/remove users from this group",
      "translated_from_hash": "15776d7f05fb",
      "origin": "machine",
      "status": "unverified"
    },
