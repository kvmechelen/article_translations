  "body_skeleton": "<p class=\"no-margin\">@@body:0001@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_51863451a9\">@@body:0002@@</h1><div class=\"intercom-container\"><img height=\"1542\" src=\"https://downloads.intercomcdn.eu/i/o/nfttr45j/130765371/f3611604a9cab9aa396ec2c7575a/Screenshot+2026-04-13+at+7_50_57%E2%80%AFAM.png?expires=1781870400&amp;signature=a30a39ec7c2a8cf4700b15bf1ba4e925e824d748b24d8cdee9d763f37135b0e2&amp;req=0dZvwl7%2FrzAplxv2%2BtxgpjEwUAtz80OQEh%2F43k4ep7QUtHAKmJBZNCFnB159%0A2s%2B1alovUK9Za1cqxpZIcDkXxQ%3D%3D%0A\" style=\"height: auto;\" width=\"2922\"/></div><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0003@@</p><ul><li><p class=\"no-margin\">@@body:0004@@</p></li><li><p class=\"no-margin\">@@body:0005@@</p></li><li><p class=\"no-margin\">@@body:0006@@</p></li><li><p class=\"no-margin\">@@body:0007@@</p></li><li><p class=\"no-margin\">@@body:0008@@</p></li></ul><p class=\"no-margin\">@@body:0009@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0010@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_e3bfaaeec9\">@@body:0011@@</h1><p class=\"no-margin\">@@body:0012@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0013@@</p><p class=\"no-margin\">@@body:0014@@</p><ul><li><p class=\"no-margin\">@@body:0015@@</p></li><li><p class=\"no-margin\">@@body:0016@@</p></li></ul><p class=\"no-margin\">@@body:0017@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0018@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_0b3036a4f0\">@@body:0019@@</h1><div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90372740/557d3a05de68cc08cb8508bec75a/upload_3165850455314516287.png?expires=1781870400&amp;signature=79d67a0ea5b3ccbfab92fb05c97fca4df9d807dcd52d9367e75289dfa1163753&amp;req=2dVswlr9qDdk2hj99dpg6hWfxHTVGqpVAh00%2Bwm7a2aNmQ4petcbcTksXUX6%0ABVcXyi9M4%2FkfVDnrR7Ub2xjQ%0A\"/></div><p class=\"no-margin\"></p>\n<ol><li><p class=\"no-margin\">@@body:0020@@</p></li><li><p class=\"no-margin\">@@body:0021@@</p></li><li><p class=\"no-margin\">@@body:0022@@</p><ul><li><p class=\"no-margin\">@@body:0023@@</p></li><li><p class=\"no-margin\">@@body:0024@@</p></li></ul></li><li><p class=\"no-margin\">@@body:0025@@</p></li></ol><p class=\"no-margin\">@@body:0026@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0027@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_3a285d035d\">@@body:0028@@</h1><h2 id=\"h_810e859d86\">@@body:0029@@</h2><ul><li><p class=\"no-margin\">@@body:0030@@</p></li><li><p class=\"no-margin\">@@body:0031@@</p></li></ul><h2 id=\"h_8c306be2b9\">@@body:0032@@</h2><ul><li><p class=\"no-margin\">@@body:0033@@</p></li><li><p class=\"no-margin\">@@body:0034@@</p></li><li><p class=\"no-margin\">@@body:0035@@</p></li></ul><h1 id=\"h_4f390c7a73\">@@body:0036@@</h1><ul><li><p class=\"no-margin\">@@body:0037@@</p></li><li><p class=\"no-margin\">@@body:0038@@</p></li><li><p class=\"no-margin\">@@body:0039@@</p></li><li><p class=\"no-margin\">@@body:0040@@</p></li></ul><h1 id=\"h_8788511a8f\">@@body:0041@@</h1><ul><li><p class=\"no-margin\">@@body:0042@@</p></li><li><p class=\"no-margin\">@@body:0043@@</p></li><li><p class=\"no-margin\">@@body:0044@@</p></li><li><p class=\"no-margin\">@@body:0045@@</p></li><li><p class=\"no-margin\">@@body:0046@@</p><p class=\"no-margin\">@@body:0047@@</p></li></ul><h1 id=\"h_eab14ca6bf\">@@body:0048@@</h1><p class=\"no-margin\">@@body:0049@@</p><ul><li><p class=\"no-margin\">@@body:0050@@</p></li><li><p class=\"no-margin\">@@body:0051@@</p></li><li><p class=\"no-margin\">@@body:0052@@</p></li></ul><h2 id=\"h_14bfdac405\">@@body:0053@@</h2><ol><li><p class=\"no-margin\">@@body:0054@@</p></li><li><p class=\"no-margin\">@@body:0055@@</p></li><li><p class=\"no-margin\">@@body:0056@@</p></li><li><p class=\"no-margin\">@@body:0057@@</p></li><li><p class=\"no-margin\">@@body:0058@@</p></li></ol><div class=\"intercom-container\"><img height=\"509\" src=\"https://downloads.intercomcdn.eu/i/o/nfttr45j/100027443/d2ccc43cd0a5ae15c45e46fe21e1/screenshot_2026-02-10_at_12_15_21_720.png?expires=1781870400&amp;signature=aa48b32332f983a4d8a8faa3fb7fa4204be2dda59ff3b3db5e93d46d30094654&amp;req=0dVvxVr9qDMrlxv2%2BtxgppPoTzPn7Hlw6u%2F3iPXLTTsh0MMbhBkLBDbx6X47%0Am%2FgsXfW2Zo9%2BF0sWQ7MRa3hAsQ%3D%3D%0A\" style=\"height: auto;\" width=\"720\"/></div><p class=\"no-margin\"></p>\n<h2 id=\"h_00b56ab38e\">@@body:0059@@</h2><ol><li><p class=\"no-margin\">@@body:0060@@</p></li><li><p class=\"no-margin\">@@body:0061@@</p></li><li><p class=\"no-margin\">@@body:0062@@</p></li><li><p class=\"no-margin\">@@body:0063@@</p></li></ol><p class=\"no-margin\">@@body:0064@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_9ad67ee4cf\">@@body:0065@@</h1><ul><li><p class=\"no-margin\">@@body:0066@@</p><ul><li><p class=\"no-margin\">@@body:0067@@</p></li><li><p class=\"no-margin\">@@body:0068@@</p></li><li><p class=\"no-margin\">@@body:0069@@</p></li></ul></li><li><p class=\"no-margin\">@@body:0070@@</p><ul><li><p class=\"no-margin\">@@body:0071@@</p></li><li><p class=\"no-margin\">@@body:0072@@</p></li><li><p class=\"no-margin\">@@body:0073@@</p></li></ul></li></ul><h1 id=\"h_82957d09ae\">@@body:0074@@</h1><p class=\"no-margin\">@@body:0075@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0076@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0077@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0078@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0079@@</p><p class=\"no-margin\"></p>",
  "segments": {
    "title": {
      "field": "title",
      "text": "User Management and User Groups",
      "hash": "403ce10cad13"
    },
    "description": {
      "field": "description",
      "text": "",
      "hash": "e3b0c44298fc"
    },
    "body:0001": {
      "field": "body",
      "text": "<i>This article is machine translated from english</i>",
      "hash": "71361155ecf7"
    },
    "body:0002": {
      "field": "body",
      "text": "Overview of user management",
      "hash": "87ffd7ab3d0a"
    },
    "body:0003": {
      "field": "body",
      "text": "The Users section in your platform's admin panel allows platform administrators to:",
      "hash": "be398f5f132d"
    },
    "body:0004": {
      "field": "body",
      "text": "Manage participants through groups",
      "hash": "704daf14cfb2"
    },
    "body:0005": {
      "field": "body",
      "text": "Grant or remove roles",
      "hash": "dd328e7198a0"
    },
    "body:0006": {
      "field": "body",
      "text": "Follow-up on user activity",
      "hash": "e2b0259a41e0"
    },
    "body:0007": {
      "field": "body",
      "text": "Export participant data",
      "hash": "31ec3e9581bc"
    },
    "body:0008": {
      "field": "body",
      "text": "Block or delete users",
      "hash": "06e1429628b8"
    },
    "body:0009": {
      "field": "body",
      "text": "The Seats Overview button allows you to have a quick view of who your Project Managers, Folder Managers and Admins are and the seats available.",
      "hash": "50e070d78285"
    },
    "body:0010": {
      "field": "body",
      "text": "ℹ️ Access restricted: Only platform administrators can access the Users section. Project and folder managers do not have access.",
      "hash": "1f3b59202451"
    },
    "body:0011": {
      "field": "body",
      "text": "What are user groups?",
      "hash": "b8975310abc6"
    },
    "body:0012": {
      "field": "body",
      "text": "A user group is a collection of users that are grouped together based on shared characteristics or can be manually defined. These groups can be used to control access and target communication efficiently.",
      "hash": "fc818b6706d1"
    },
    "body:0013": {
      "field": "body",
      "text": "User groups allow you to organize participants for targeted communication and to manage viewing or participation rights on projects.",
      "hash": "b181bf39e0db"
    },
    "body:0014": {
      "field": "body",
      "text": "There are two types:",
      "hash": "f79fbdcef94d"
    },
    "body:0015": {
      "field": "body",
      "text": "<b>Manual Groups:</b> You add users manually",
      "hash": "765863cff7ca"
    },
    "body:0016": {
      "field": "body",
      "text": "<b>Smart Groups:</b> Users are automatically added when they meet set conditions (e.g., lives in a certain neighborhood, age, profession)",
      "hash": "1e7422586df1"
    },
    "body:0017": {
      "field": "body",
      "text": "Smart Groups are indicated by ⚡️ in the Users tab.",
      "hash": "0b61e67068a1"
    },
    "body:0018": {
      "field": "body",
      "text": "ℹ️ Note: Since smart groups are set with specific conditions, it is not possible to manually add/remove users from this group",
      "hash": "15776d7f05fb"
    },
    "body:0019": {
      "field": "body",
      "text": "How to create a group?",
      "hash": "4421aabec79d"
    },
    "body:0020": {
      "field": "body",
      "text": "Go to <b>Users</b> in the admin panel",
      "hash": "34d583413d5c"
    },
    "body:0021": {
      "field": "body",
      "text": "Click the <b>+</b> icon in the left grey column",
      "hash": "bf734614e4a5"
    },
    "body:0022": {
      "field": "body",
      "text": "Choose:",
      "hash": "accc7c658c6a"
    },
    "body:0023": {
      "field": "body",
      "text": "<b>Manual Group:</b> Add users manually.",
      "hash": "b39ffe3dc6b1"
    },
    "body:0024": {
      "field": "body",
      "text": "<b>Smart Group:</b> Define one or more conditions (e.g., <i>Lives in = Brussels</i>).",
      "hash": "c84ba7bbd1a8"
    },
    "body:0025": {
      "field": "body",
      "text": "Save the group.",
      "hash": "4c72f3676631"
    },
    "body:0026": {
      "field": "body",
      "text": "ℹ️ Note: The attribute <b>Posted an input</b> is used to filter both for users that submitted an idea in an ideation phase as well as users that submitted a survey in a survey phase.",
      "hash": "23f6f9a73424"
    },
    "body:0027": {
      "field": "body",
      "text": "⚠️ Smart Group logic is AND‑only, users must meet all conditions you set.",
      "hash": "dfbb799c7e62"
    },
    "body:0028": {
      "field": "body",
      "text": "Accessing group data",
      "hash": "cdea5b5ac5f5"
    },
    "body:0029": {
      "field": "body",
      "text": "Following up on user group activity",
      "hash": "e0189ad070cc"
    },
    "body:0030": {
      "field": "body",
      "text": "Go to <b>Dashboard → User tab</b>",
      "hash": "0a958492a92e"
    },
    "body:0031": {
      "field": "body",
      "text": "Filter by group to see user activity and behaviour",
      "hash": "00bfd917dca5"
    },
    "body:0032": {
      "field": "body",
      "text": "Exporting user group data",
      "hash": "022fecc2c00d"
    },
    "body:0033": {
      "field": "body",
      "text": "Go to <b>Users</b>",
      "hash": "52e5b880f313"
    },
    "body:0034": {
      "field": "body",
      "text": "Select the group from which you want to expert the user data",
      "hash": "61e772c05f77"
    },
    "body:0035": {
      "field": "body",
      "text": "Press <b>export users in group</b>",
      "hash": "23fca474d63d"
    },
    "body:0036": {
      "field": "body",
      "text": "How to block a user?",
      "hash": "faa0863a9faf"
    },
    "body:0037": {
      "field": "body",
      "text": "In the <b>Users</b> section, click the <b>three dots</b> next to the user",
      "hash": "d948b4f785e1"
    },
    "body:0038": {
      "field": "body",
      "text": "Select <b>Block user</b>",
      "hash": "5cf3bee01a75"
    },
    "body:0039": {
      "field": "body",
      "text": "Add a <b>reason</b> in the pop-up",
      "hash": "077ed9311b9e"
    },
    "body:0040": {
      "field": "body",
      "text": "Confirm the ban (default: 90 days)",
      "hash": "f2ceb197aa7e"
    },
    "body:0041": {
      "field": "body",
      "text": "Blocking behaviour on our platform",
      "hash": "fac3706847b5"
    },
    "body:0042": {
      "field": "body",
      "text": "User is notified of ban and reason",
      "hash": "0d790d2f787f"
    },
    "body:0043": {
      "field": "body",
      "text": "Session ends on next action",
      "hash": "83a3d98b3e22"
    },
    "body:0044": {
      "field": "body",
      "text": "Login attempts are blocked",
      "hash": "e4689f948b82"
    },
    "body:0045": {
      "field": "body",
      "text": "Content stays on platform, moderate manually if needed",
      "hash": "94b812b4ecd4"
    },
    "body:0046": {
      "field": "body",
      "text": "Default ban duration can be adjusted via support",
      "hash": "e4168325e840"
    },
    "body:0047": {
      "field": "body",
      "text": "<br/>ℹ️ Access to this feature depends on your subscription plan.",
      "hash": "041d43eccbc9"
    },
    "body:0048": {
      "field": "body",
      "text": "How to delete a user?",
      "hash": "5ba3cced48f7"
    },
    "body:0049": {
      "field": "body",
      "text": "Use delete in specific cases only:",
      "hash": "34f54646d441"
    },
    "body:0050": {
      "field": "body",
      "text": "Test accounts",
      "hash": "0526b433ccf2"
    },
    "body:0051": {
      "field": "body",
      "text": "Fake accounts",
      "hash": "542fc91cb7fc"
    },
    "body:0052": {
      "field": "body",
      "text": "Repeat violations",
      "hash": "50fbcb51240b"
    },
    "body:0053": {
      "field": "body",
      "text": "Steps to Delete a User from the platform",
      "hash": "79967fe5b19b"
    },
    "body:0054": {
      "field": "body",
      "text": "Go to the <b>Users</b> section",
      "hash": "6bfcd461a44f"
    },
    "body:0055": {
      "field": "body",
      "text": "Click the <b>three dots</b> in <b>Options</b>",
      "hash": "907b0821edce"
    },
    "body:0056": {
      "field": "body",
      "text": "Select <b>Delete this user</b>",
      "hash": "22e578e60526"
    },
    "body:0057": {
      "field": "body",
      "text": "You can then decide to delete the user's participation data too (if not it will simply be anonymize when they are deleted)",
      "hash": "7f18d37b2483"
    },
    "body:0058": {
      "field": "body",
      "text": "You can also decide to ban the email so they cannot register again",
      "hash": "c3b9eca331aa"
    },
    "body:0059": {
      "field": "body",
      "text": "Steps to Delete a User from a manual group",
      "hash": "58cc59f03e56"
    },
    "body:0060": {
      "field": "body",
      "text": "Go to the <b>Users</b> section",
      "hash": "6bfcd461a44f"
    },
    "body:0061": {
      "field": "body",
      "text": "Click the <b>User Group</b> you want to remove the user from",
      "hash": "8cb7a9b8b8a1"
    },
    "body:0062": {
      "field": "body",
      "text": "Toggle the <b>square</b> on the left<b> </b>to select the user(s) you want to remove",
      "hash": "edfb3e01ab86"
    },
    "body:0063": {
      "field": "body",
      "text": "Select <b>Remove from group</b>",
      "hash": "6118c49596e4"
    },
    "body:0064": {
      "field": "body",
      "text": "⚠️ When removing a user from a group, make sure not to delete them from the platform",
      "hash": "33bea7b1ca07"
    },
    "body:0065": {
      "field": "body",
      "text": "Difference between a blocked and deleted user",
      "hash": "df76e49ea49c"
    },
    "body:0066": {
      "field": "body",
      "text": "<b>Blocking:</b>",
      "hash": "718fe9bec956"
    },
    "body:0067": {
      "field": "body",
      "text": "Temporary (default 90 days)",
      "hash": "2dfc53d68d60"
    },
    "body:0068": {
      "field": "body",
      "text": "User cannot log in or create new account",
      "hash": "656da20cf283"
    },
    "body:0069": {
      "field": "body",
      "text": "Content stays on the platform",
      "hash": "d23f6d79c6d6"
    },
    "body:0070": {
      "field": "body",
      "text": "<b>Deleting:</b>",
      "hash": "c66447920ed5"
    },
    "body:0071": {
      "field": "body",
      "text": "Permanent",
      "hash": "455a95491f40"
    },
    "body:0072": {
      "field": "body",
      "text": "User account is removed entirely",
      "hash": "5dbce1156fa8"
    },
    "body:0073": {
      "field": "body",
      "text": "Content remains, but user loses access",
      "hash": "55d728495f2a"
    },
    "body:0074": {
      "field": "body",
      "text": "Example use cases for smart groups",
      "hash": "66732c80c386"
    },
    "body:0075": {
      "field": "body",
      "text": "Example 1: Email all users who haven’t participated in a project",
      "hash": "e8ba68256117"
    },
    "body:0076": {
      "field": "body",
      "text": "Condition: <code>Contributed to project → Didn’t contribute → [project name]</code>",
      "hash": "f2e15a9caf81"
    },
    "body:0077": {
      "field": "body",
      "text": "Example 2: Email all registered users",
      "hash": "023989972adb"
    },
    "body:0078": {
      "field": "body",
      "text": "Condition: <code>Registration date → Is not empty</code>",
      "hash": "80534759bae2"
    },
    "body:0079": {
      "field": "body",
      "text": "⚠️ You cannot create Smart Groups based on email opens/clicks, contact Support to manually retrieve these user lists.",
      "hash": "61409257f2d4"
    }
  }
}