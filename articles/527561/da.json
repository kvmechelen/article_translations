    },
    "body:0002": {
      "field": "body",
      "source": "The text editor is where you create and format your content. It’s a WYSIWYG (“What You See Is What You Get”) editor, meaning your content appears the same during editing as it will when published. Below, you’ll find how to format text, add media, and manage images in the editor.",
      "source_hash": "b26448c50669",
      "target": "The text editor is where you create and format your content. It’s a WYSIWYG (“What You See Is What You Get”) editor, meaning your content appears the same during editing as it will when published. Below, you’ll find how to format text, add media, and manage images in the editor.",
      "translated_from_hash": "b26448c50669",
      "origin": "machine",
      "status": "unverified"
    },
