  "body_skeleton": "<h1 id=\"h_aa3c4655eb\">@@body:0001@@</h1><p class=\"no-margin\">@@body:0002@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0003@@</p><ul><li><p class=\"no-margin\">@@body:0004@@</p></li><li><p class=\"no-margin\">@@body:0005@@</p></li><li><p class=\"no-margin\">@@body:0006@@</p></li><li><p class=\"no-margin\">@@body:0007@@</p></li></ul><h1 id=\"h_1433515624\">@@body:0008@@</h1><p class=\"no-margin\">@@body:0009@@</p><ul><li><p class=\"no-margin\">@@body:0010@@</p></li><li><p class=\"no-margin\">@@body:0011@@</p></li><li><p class=\"no-margin\">@@body:0012@@</p></li><li><p class=\"no-margin\">@@body:0013@@</p></li><li><p class=\"no-margin\">@@body:0014@@</p></li><li><p class=\"no-margin\">@@body:0015@@</p></li><li><p class=\"no-margin\">@@body:0016@@</p></li><li><p class=\"no-margin\">@@body:0017@@</p></li><li><p class=\"no-margin\">@@body:0018@@</p></li></ul><p class=\"no-margin\">@@body:0019@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_c98dcbddd9\">@@body:0020@@</h1><h2 id=\"h_c9ba168d1d\">@@body:0021@@</h2><p class=\"no-margin\">@@body:0022@@</p><p class=\"no-margin\"></p>\n<h2 id=\"h_9fff03c206\">@@body:0023@@</h2><ul><li><p class=\"no-margin\">@@body:0024@@</p></li><li><p class=\"no-margin\">@@body:0025@@</p></li><li><p class=\"no-margin\">@@body:0026@@</p><p class=\"no-margin\">@@body:0027@@</p><p class=\"no-margin\">@@body:0028@@</p></li></ul><p class=\"no-margin\">@@body:0029@@</p><p class=\"no-margin\"></p>\n<h2 id=\"h_a4fc7bfcef\">@@body:0030@@</h2><ul><li><p class=\"no-margin\">@@body:0031@@</p></li><li><p class=\"no-margin\">@@body:0032@@</p><p class=\"no-margin\">@@body:0033@@</p><p class=\"no-margin\">@@body:0034@@</p></li></ul><h2 id=\"h_7dba98d219\">@@body:0035@@</h2><ul><li><p class=\"no-margin\">@@body:0036@@</p><p class=\"no-margin\">@@body:0037@@</p><p class=\"no-margin\">@@body:0038@@</p></li></ul><h2 id=\"h_a2f9394a9d\">@@body:0039@@</h2><ul><li><p class=\"no-margin\">@@body:0040@@</p></li><li><p class=\"no-margin\">@@body:0041@@</p></li><li><p class=\"no-margin\">@@body:0042@@</p></li></ul><h1 id=\"h_192e29a8b7\">@@body:0043@@</h1><ol><li><p class=\"no-margin\">@@body:0044@@</p><p class=\"no-margin\">@@body:0045@@</p></li><li><p class=\"no-margin\">@@body:0046@@</p><ul><li><p class=\"no-margin\">@@body:0047@@</p></li><li><p class=\"no-margin\">@@body:0048@@</p></li><li><p class=\"no-margin\">@@body:0049@@</p></li></ul></li><li><p class=\"no-margin\">@@body:0050@@</p><ul><li><p class=\"no-margin\">@@body:0051@@</p></li><li><p class=\"no-margin\">@@body:0052@@</p></li><li><p class=\"no-margin\">@@body:0053@@</p></li></ul></li></ol><p class=\"no-margin\">@@body:0054@@</p><p class=\"no-margin\"></p>\n<div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90372957/8ff4b455ec518dbafe93985966e9/upload_15766083814467842770.png?expires=1781870400&amp;signature=d1f0cfba3e1396f543a7015b8d3d4ed61ca8d2c2ed9e0be6fea1912d7e38a041&amp;req=2dVswlrzqTBk2hj99dpg6jpQo40sPgym9zN2NaE5gJ3Lm%2Bz6mAqnXv9kqBKx%0Ax7tXzd47U4m8kFqIGydGGA13%0A\"/></div><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0055@@</p><ul><li><p class=\"no-margin\">@@body:0056@@</p></li><li><p class=\"no-margin\">@@body:0057@@</p></li><li><p class=\"no-margin\">@@body:0058@@</p></li></ul><p class=\"no-margin\"></p>\n<h1 id=\"h_a0fd9ce404\">@@body:0059@@</h1><p class=\"no-margin\">@@body:0060@@</p><ul><li><p class=\"no-margin\">@@body:0061@@</p></li><li><p class=\"no-margin\">@@body:0062@@</p></li></ul><p class=\"no-margin\">@@body:0063@@</p><ol><li><p class=\"no-margin\">@@body:0064@@</p></li><li><p class=\"no-margin\">@@body:0065@@</p><ul><li><p class=\"no-margin\">@@body:0066@@</p><ul><li><p class=\"no-margin\">@@body:0067@@</p></li></ul></li><li><p class=\"no-margin\">@@body:0068@@</p><ul><li><p class=\"no-margin\">@@body:0069@@</p></li><li><p class=\"no-margin\">@@body:0070@@</p></li><li><p class=\"no-margin\">@@body:0071@@</p></li><li><p class=\"no-margin\">@@body:0072@@</p></li></ul></li></ul></li></ol>",
  "segments": {
    "title": {
      "field": "title",
      "text": "Creating an external survey project",
      "hash": "16c6d88a8123"
    },
    "description": {
      "field": "description",
      "text": "",
      "hash": "e3b0c44298fc"
    },
    "body:0001": {
      "field": "body",
      "text": "When should you use external surveys?",
      "hash": "21f22734dc8e"
    },
    "body:0002": {
      "field": "body",
      "text": "External survey tools are useful when you need advanced features not offered by the Go Vocal survey builder or if your organization is already using third-party survey tools.",
      "hash": "7010b061b1d9"
    },
    "body:0003": {
      "field": "body",
      "text": "However, we recommend using Go Vocal’s built-in survey tool whenever possible for:",
      "hash": "881165411211"
    },
    "body:0004": {
      "field": "body",
      "text": "In-platform data analysis",
      "hash": "98829e0a2aca"
    },
    "body:0005": {
      "field": "body",
      "text": "In-platform reporting",
      "hash": "721ce671a950"
    },
    "body:0006": {
      "field": "body",
      "text": "Direct linkage with registration data",
      "hash": "23e1d953be8f"
    },
    "body:0007": {
      "field": "body",
      "text": "A consistent user experience",
      "hash": "b8c950cdbc80"
    },
    "body:0008": {
      "field": "body",
      "text": "Which external survey tools are supported by govocal?",
      "hash": "615c471cd281"
    },
    "body:0009": {
      "field": "body",
      "text": "You can embed surveys from the following services (depending on your plan):",
      "hash": "a9ac90323840"
    },
    "body:0010": {
      "field": "body",
      "text": "Typeform (recommended)",
      "hash": "3530290cc57f"
    },
    "body:0011": {
      "field": "body",
      "text": "Google Forms",
      "hash": "805259086913"
    },
    "body:0012": {
      "field": "body",
      "text": "Enalyzer",
      "hash": "5841d2fac8c9"
    },
    "body:0013": {
      "field": "body",
      "text": "Qualtrics",
      "hash": "28d3793c1e35"
    },
    "body:0014": {
      "field": "body",
      "text": "Microsoft Forms",
      "hash": "7645f2073fc8"
    },
    "body:0015": {
      "field": "body",
      "text": "SurveyXact",
      "hash": "01286ed385cc"
    },
    "body:0016": {
      "field": "body",
      "text": "SurveyMonkey",
      "hash": "1f160392c8bd"
    },
    "body:0017": {
      "field": "body",
      "text": "Snap Surveys",
      "hash": "65e36f945302"
    },
    "body:0018": {
      "field": "body",
      "text": "SmartSurvey",
      "hash": "453dcc2bb218"
    },
    "body:0019": {
      "field": "body",
      "text": "If your desired tool doesn’t appear in the platform dropdown, contact support via the chat bubble or email <a class=\"intercom-content-link\" href=\"mailto:support@govocal.com\" target=\"_blank\">support@govocal.com</a> to enable it.",
      "hash": "293048640af7"
    },
    "body:0020": {
      "field": "body",
      "text": "Where to find your embed URL for your external survey?",
      "hash": "bb18b813ff49"
    },
    "body:0021": {
      "field": "body",
      "text": "Typeform",
      "hash": "2bcaf210c1ce"
    },
    "body:0022": {
      "field": "body",
      "text": "Copy the public survey URL. Hidden fields (like user ID or email) can be added.",
      "hash": "75c5610a6a15"
    },
    "body:0023": {
      "field": "body",
      "text": "Google Forms",
      "hash": "805259086913"
    },
    "body:0024": {
      "field": "body",
      "text": "Click <b>Send</b> → Select <code>&lt; &gt;</code> icon → Copy Embed HTML",
      "hash": "798565957477"
    },
    "body:0025": {
      "field": "body",
      "text": "Remove <code>&lt;iframe ... src=\"</code> at the start",
      "hash": "722b412f4979"
    },
    "body:0026": {
      "field": "body",
      "text": "Remove everything starting from <code>\" width=</code> at the end",
      "hash": "d8ff5741651b"
    },
    "body:0027": {
      "field": "body",
      "text": "Final URL should look like:",
      "hash": "685e27edf5b2"
    },
    "body:0028": {
      "field": "body",
      "text": "<code>https://docs.google.com/forms/d/e/.../viewform?embedded=true</code>",
      "hash": "7337315841f9"
    },
    "body:0029": {
      "field": "body",
      "text": "💡 Limit scale questions to 6 options for mobile-friendly display.",
      "hash": "785fafdbbea0"
    },
    "body:0030": {
      "field": "body",
      "text": "SurveyXact",
      "hash": "01286ed385cc"
    },
    "body:0031": {
      "field": "body",
      "text": "In SurveyXact, go to <b>Distribution</b> &gt; <b>Self-creation</b>",
      "hash": "9fbbf9ec16b8"
    },
    "body:0032": {
      "field": "body",
      "text": "Enable it and copy the link from the <b>Link</b> tab",
      "hash": "751d1a443b1c"
    },
    "body:0033": {
      "field": "body",
      "text": "Example:",
      "hash": "872887e563e7"
    },
    "body:0034": {
      "field": "body",
      "text": "<code>http://www.survey-xact.dk/LinkCollector?key=XYZ123</code>",
      "hash": "bb4e73d21103"
    },
    "body:0035": {
      "field": "body",
      "text": "Enalyzer",
      "hash": "5841d2fac8c9"
    },
    "body:0036": {
      "field": "body",
      "text": "Click <b>Share Link</b> to copy the embed URL",
      "hash": "c85df3b65109"
    },
    "body:0037": {
      "field": "body",
      "text": "Example:",
      "hash": "872887e563e7"
    },
    "body:0038": {
      "field": "body",
      "text": "<code>https://surveys.enalyzer.com?pid=abc123</code>",
      "hash": "96a2f315820a"
    },
    "body:0039": {
      "field": "body",
      "text": "SmartSurvey",
      "hash": "453dcc2bb218"
    },
    "body:0040": {
      "field": "body",
      "text": "First try the link under <b>Collect</b>",
      "hash": "4b52d6cfa2fe"
    },
    "body:0041": {
      "field": "body",
      "text": "If it doesn’t work, go to <b>Web Embed</b> and select <i>“my embed code is not working”</i>",
      "hash": "e791787e16f9"
    },
    "body:0042": {
      "field": "body",
      "text": "Use the provided link and <b>enable framing</b> under <b>Settings</b>",
      "hash": "88e3e43a5546"
    },
    "body:0043": {
      "field": "body",
      "text": "How to embed an external survey?",
      "hash": "9d7abbd3d3ce"
    },
    "body:0044": {
      "field": "body",
      "text": "<b>Create your survey</b>",
      "hash": "9af7901590f5"
    },
    "body:0045": {
      "field": "body",
      "text": "Use your preferred external tool to build your survey.",
      "hash": "e4d3f2d3c75f"
    },
    "body:0046": {
      "field": "body",
      "text": "<b>Set up your project or timeline phase</b>",
      "hash": "aee5e2c20a88"
    },
    "body:0047": {
      "field": "body",
      "text": "In Go Vocal, create a new project or a phase.",
      "hash": "15bbd22668c8"
    },
    "body:0048": {
      "field": "body",
      "text": "Choose <b>Create a survey</b> as the participation method.",
      "hash": "4804e0c189d5"
    },
    "body:0049": {
      "field": "body",
      "text": "Choose the survey option <b>External survey</b>",
      "hash": "f34fcbb64a0a"
    },
    "body:0050": {
      "field": "body",
      "text": "<b>Paste the Embed URL</b>",
      "hash": "ec265f5aa282"
    },
    "body:0051": {
      "field": "body",
      "text": "Select your survey tool from the dropdown.",
      "hash": "6c99ba2d44a6"
    },
    "body:0052": {
      "field": "body",
      "text": "Paste the cleaned embed URL into the input field.",
      "hash": "945a2622bf62"
    },
    "body:0053": {
      "field": "body",
      "text": "Click <b>Save</b>.",
      "hash": "b983d161b2a2"
    },
    "body:0054": {
      "field": "body",
      "text": "ℹ️ You must provide the survey URL when creating the phase; it can’t be added later. Set the project to <i>draft</i> if the survey isn’t ready yet.",
      "hash": "1594353d2df7"
    },
    "body:0055": {
      "field": "body",
      "text": "4. <b>(Optional) Link user data in Typeform</b>",
      "hash": "49651fcc9ce2"
    },
    "body:0056": {
      "field": "body",
      "text": "Typeform supports hidden fields to track user emails or IDs.",
      "hash": "2128f97b20cd"
    },
    "body:0057": {
      "field": "body",
      "text": "Results can be downloaded directly from Go Vocal.",
      "hash": "43267bce868b"
    },
    "body:0058": {
      "field": "body",
      "text": "See: <i>Using Hidden Fields in Typeform</i>",
      "hash": "0647fadafc98"
    },
    "body:0059": {
      "field": "body",
      "text": "<b>Phase access and user data</b> for external surveys",
      "hash": "feabf28b2c1a"
    },
    "body:0060": {
      "field": "body",
      "text": "The external survey method offers 2 types of <b>Authentication</b> for who can take the survey:",
      "hash": "cc385f701f25"
    },
    "body:0061": {
      "field": "body",
      "text": "<b>Email confirmation</b>",
      "hash": "a3db689d6e8b"
    },
    "body:0062": {
      "field": "body",
      "text": "<b>Account creation</b>",
      "hash": "593294dd0204"
    },
    "body:0063": {
      "field": "body",
      "text": "If you prefer <b>Authentication = None</b>, use the in-platform survey tool instead. If not, follow this workaround:",
      "hash": "68bc5fd4d9e6"
    },
    "body:0064": {
      "field": "body",
      "text": "In the <b>Setup</b> tab, change the participation method to <b>Share information</b> instead of <b>External survey</b>.",
      "hash": "accfae7022b6"
    },
    "body:0065": {
      "field": "body",
      "text": "Then, you can choose one of the following:",
      "hash": "672cb21ad751"
    },
    "body:0066": {
      "field": "body",
      "text": "<b>Option 1:</b> Create a button in the phase description:",
      "hash": "4120b5e1d558"
    },
    "body:0067": {
      "field": "body",
      "text": "Click the link icon and paste your external survey link.",
      "hash": "265cda816ed3"
    },
    "body:0068": {
      "field": "body",
      "text": "<b>Option 2:</b> Go to the <b>Report</b> tab and create a new blank report:",
      "hash": "1dafb8ee687b"
    },
    "body:0069": {
      "field": "body",
      "text": "Drag and drop the embed widget.",
      "hash": "ce2ec2b27f2c"
    },
    "body:0070": {
      "field": "body",
      "text": "Add the embed URL of the external survey.",
      "hash": "e545ce474500"
    },
    "body:0071": {
      "field": "body",
      "text": "Save the report and exit.",
      "hash": "669b4727cb73"
    },
    "body:0072": {
      "field": "body",
      "text": "Toggle \"visible\" to embed the external survey on the phase.",
      "hash": "df408b321346"
    }
  }
}