  "body_skeleton": "<p class=\"no-margin\">@@body:0001@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_221f1226e4\">@@body:0002@@</h1><p class=\"no-margin\">@@body:0003@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0004@@</p><ul><li><p class=\"no-margin\">@@body:0005@@</p></li><li><p class=\"no-margin\">@@body:0006@@</p></li><li><p class=\"no-margin\">@@body:0007@@</p></li><li><p class=\"no-margin\">@@body:0008@@</p></li><li><p class=\"no-margin\">@@body:0009@@</p></li><li><p class=\"no-margin\">@@body:0010@@</p></li><li><p class=\"no-margin\">@@body:0011@@</p></li><li><p class=\"no-margin\">@@body:0012@@</p></li></ul><h1 id=\"h_f2adb23bdd\">@@body:0013@@</h1><p class=\"no-margin\">@@body:0014@@</p><ul><li><p class=\"no-margin\">@@body:0015@@</p></li><li><p class=\"no-margin\">@@body:0016@@</p></li><li><p class=\"no-margin\">@@body:0017@@</p></li></ul><p class=\"no-margin\">@@body:0018@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_6cad62bf55\">@@body:0019@@</h1><ul><li><p class=\"no-margin\">@@body:0020@@</p></li><li><p class=\"no-margin\">@@body:0021@@</p></li><li><p class=\"no-margin\">@@body:0022@@</p></li></ul><p class=\"no-margin\">@@body:0023@@</p><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0024@@</p><p class=\"no-margin\"></p>\n<h1 id=\"h_d95a60459f\">@@body:0025@@</h1><h2 id=\"h_b79b443416\">@@body:0026@@</h2><ul><li><p class=\"no-margin\">@@body:0027@@</p></li><li><p class=\"no-margin\">@@body:0028@@</p></li><li><p class=\"no-margin\">@@body:0029@@</p></li></ul><p class=\"no-margin\">@@body:0030@@</p><p class=\"no-margin\"></p>\n<h2 id=\"h_2025b44956\">@@body:0031@@</h2><ul><li><p class=\"no-margin\">@@body:0032@@</p></li><li><p class=\"no-margin\">@@body:0033@@</p></li><li><p class=\"no-margin\">@@body:0034@@</p></li></ul><h2 id=\"h_bfa3df33f0\">@@body:0035@@</h2><ul><li><p class=\"no-margin\">@@body:0036@@</p></li><li><p class=\"no-margin\">@@body:0037@@</p></li><li><p class=\"no-margin\">@@body:0038@@</p></li></ul><h2 id=\"h_0cf81f79a0\">@@body:0039@@</h2><ul><li><p class=\"no-margin\">@@body:0040@@</p></li><li><p class=\"no-margin\">@@body:0041@@</p></li><li><p class=\"no-margin\">@@body:0042@@</p></li></ul><h2 id=\"h_eb5c009a29\">@@body:0043@@</h2><ul><li><p class=\"no-margin\">@@body:0044@@</p></li><li><p class=\"no-margin\">@@body:0045@@</p></li><li><p class=\"no-margin\">@@body:0046@@</p></li></ul><h2 id=\"h_d0bdadc8c6\">@@body:0047@@</h2><ul><li><p class=\"no-margin\">@@body:0048@@</p></li><li><p class=\"no-margin\">@@body:0049@@</p></li><li><p class=\"no-margin\">@@body:0050@@</p></li></ul><h2 id=\"h_9a939c7af7\">@@body:0051@@</h2><ul><li><p class=\"no-margin\">@@body:0052@@</p></li><li><p class=\"no-margin\">@@body:0053@@</p></li><li><p class=\"no-margin\">@@body:0054@@</p></li></ul><h2 id=\"h_c544e33a2b\">@@body:0055@@</h2><ul><li><p class=\"no-margin\">@@body:0056@@</p></li><li><p class=\"no-margin\">@@body:0057@@</p></li><li><p class=\"no-margin\">@@body:0058@@</p></li></ul><h1 id=\"h_7624363298\">@@body:0059@@</h1><p class=\"no-margin\">@@body:0060@@</p><p class=\"no-margin\"></p>\n<h2 id=\"h_bfc0798d98\">@@body:0061@@</h2><ul><li><p class=\"no-margin\">@@body:0062@@</p></li><li><p class=\"no-margin\">@@body:0063@@</p></li><li><p class=\"no-margin\">@@body:0064@@</p></li></ul><h2 id=\"h_b9041aac9b\">@@body:0065@@</h2><ul><li><p class=\"no-margin\">@@body:0066@@</p></li><li><p class=\"no-margin\">@@body:0067@@</p></li></ul><h2 id=\"h_b0075fff50\">@@body:0068@@</h2><ul><li><p class=\"no-margin\">@@body:0069@@</p></li><li><p class=\"no-margin\">@@body:0070@@</p></li><li><p class=\"no-margin\">@@body:0071@@</p></li></ul><p class=\"no-margin\">@@body:0072@@</p><p class=\"no-margin\"></p>\n<div class=\"intercom-h2b-video\"><iframe allow=\"autoplay; fullscreen; picture-in-picture; encrypted-media\" allowfullscreen=\"\" frameborder=\"0\" mozallowfullscreen=\"\" src=\"https://www.loom.com/embed/503ba4b0509e422c9e02a05ef6b76d03\" webkitallowfullscreen=\"\"></iframe></div><h1 id=\"h_80c132b1b0\">@@body:0073@@</h1><ul><li><p class=\"no-margin\">@@body:0074@@</p></li></ul><div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90374322/40774ac6770234cb6d7931917089/upload_3465582985625129094.png?expires=1781805600&amp;signature=faf5285a2caabd0e2df9da34735e285112813c82d92828e9a34868ed698a9f9c&amp;req=2dVswlz5rjVk2hj99dpg6hxLJj3ZgzLSy61FipRM8rPuXVNheQNTzOmvNpYs%0ApRJw8hLpASCJ7ZR%2FnFqjALS%2F%0A\"/></div><ul><li><p class=\"no-margin\">@@body:0075@@</p></li></ul><div class=\"intercom-container\"><img src=\"https://govocal---eu.intercom-attachments.eu/i/o/nfttr45j/90374337/4d8d4994d273793380b2564f7036/upload_4432333110132197016.png?expires=1781805600&amp;signature=6fdc1d0b23669173a00979837729f1054e3e81f7ec087c84c6d27d2f8ee245f1&amp;req=2dVswlz5rzBk2hj99dpg6i2G2PF8Erxkg6mxW9wzEh65A22UpvnkcFwBPx8i%0ACmaM%2FoRi%2F1JiPU9N246zrhIy%0A\"/></div><p class=\"no-margin\"></p>\n<p class=\"no-margin\">@@body:0076@@</p>",
  "segments": {
    "title": {
      "field": "title",
      "text": "What are the recommended dimensions and sizes of the platform images ?",
      "hash": "62549d1ad804"
    },
    "description": {
      "field": "description",
      "text": "",
      "hash": "e3b0c44298fc"
    },
    "body:0001": {
      "field": "body",
      "text": "<i>This article is machine translated from english</i>",
      "hash": "71361155ecf7"
    },
    "body:0002": {
      "field": "body",
      "text": "What are images on our platform?",
      "hash": "634544df6fba"
    },
    "body:0003": {
      "field": "body",
      "text": "Your platform allows visual customization through images or designed graphics. These visuals enhance user engagement and provide a professional and branded look.",
      "hash": "9fcab148d0a8"
    },
    "body:0004": {
      "field": "body",
      "text": "Here are the primary places where images are used:",
      "hash": "76cbfecdebb5"
    },
    "body:0005": {
      "field": "body",
      "text": "Homepage banner",
      "hash": "7d1a3dfb6b32"
    },
    "body:0006": {
      "field": "body",
      "text": "Project or folder card (in project/folder settings; visible on the homepage or within folders)",
      "hash": "b738f056c5ce"
    },
    "body:0007": {
      "field": "body",
      "text": "Project or folder banner (see header image in the project/folder settings; appears at the top of the project/folder page)",
      "hash": "0fe2ffded397"
    },
    "body:0008": {
      "field": "body",
      "text": "Input (idea) card (shown above individual inputs or in input overviews)",
      "hash": "f53dd1e38ddf"
    },
    "body:0009": {
      "field": "body",
      "text": "Logo",
      "hash": "d707dc2f1936"
    },
    "body:0010": {
      "field": "body",
      "text": "In-text images",
      "hash": "6dc907a2e033"
    },
    "body:0011": {
      "field": "body",
      "text": "Proposals",
      "hash": "834cfc1ee237"
    },
    "body:0012": {
      "field": "body",
      "text": "Event cards",
      "hash": "105ef9125206"
    },
    "body:0013": {
      "field": "body",
      "text": "What are the image file requirements?",
      "hash": "819c5cbcf9b8"
    },
    "body:0014": {
      "field": "body",
      "text": "To maintain clarity:",
      "hash": "19ce3dd33ab5"
    },
    "body:0015": {
      "field": "body",
      "text": "Use PNG or JPG formats",
      "hash": "9c9a140be782"
    },
    "body:0016": {
      "field": "body",
      "text": "File size must not exceed 10 MB",
      "hash": "ac0529828a98"
    },
    "body:0017": {
      "field": "body",
      "text": "Use a resolution of at least 72 dpi (dots per inch)",
      "hash": "09d2f5b2a081"
    },
    "body:0018": {
      "field": "body",
      "text": "💡 A higher dpi ensures your image appears crisp and not pixelated.",
      "hash": "2ea41f15f24c"
    },
    "body:0019": {
      "field": "body",
      "text": "What are the requirements for attachments on the platform?",
      "hash": "79e190d8bf5b"
    },
    "body:0020": {
      "field": "body",
      "text": "Each file (e.g., image, PDF) can be up to 50 MB",
      "hash": "47f3edf0648b"
    },
    "body:0021": {
      "field": "body",
      "text": "No limit to the number of attachments per project",
      "hash": "f694f9eb1547"
    },
    "body:0022": {
      "field": "body",
      "text": "However, uploading many large files can slow down performance",
      "hash": "bdf217c71ae9"
    },
    "body:0023": {
      "field": "body",
      "text": "<b>⚠️ </b>Attached files are automatically downloaded when clicked.",
      "hash": "0ccc4884b2cd"
    },
    "body:0024": {
      "field": "body",
      "text": "💡 If you want the file to open in a new tab, use the hyperlink tool to insert a direct URL to the file hosted online.",
      "hash": "0d8fdddd8644"
    },
    "body:0025": {
      "field": "body",
      "text": "What are the recommended dimensions for different images on the platform?",
      "hash": "c16366340b6e"
    },
    "body:0026": {
      "field": "body",
      "text": "Homepage banner",
      "hash": "7d1a3dfb6b32"
    },
    "body:0027": {
      "field": "body",
      "text": "Recommended dimensions: 1440 × 480 px",
      "hash": "6abca09022a8"
    },
    "body:0028": {
      "field": "body",
      "text": "Aspect ratio: 3:1",
      "hash": "52a58b63b24c"
    },
    "body:0029": {
      "field": "body",
      "text": "On mobile: typically displays closer to 1:1",
      "hash": "35882c724b26"
    },
    "body:0030": {
      "field": "body",
      "text": "ℹ️ You can choose different banner styles (see next section)",
      "hash": "4eaa8e8e9214"
    },
    "body:0031": {
      "field": "body",
      "text": "Project/folder card",
      "hash": "42503ecfde54"
    },
    "body:0032": {
      "field": "body",
      "text": "Dimensions: 1400 × 1050 px",
      "hash": "c643be92d5e7"
    },
    "body:0033": {
      "field": "body",
      "text": "Aspect ratio: 4:3",
      "hash": "6fa96905a3f7"
    },
    "body:0034": {
      "field": "body",
      "text": "On mobile: maintains 4:3 ratio",
      "hash": "3b2aa737ff0e"
    },
    "body:0035": {
      "field": "body",
      "text": "Project/folder banner",
      "hash": "b4fc501121a9"
    },
    "body:0036": {
      "field": "body",
      "text": "Dimensions: 2400 x 600 px",
      "hash": "bfe466a798d2"
    },
    "body:0037": {
      "field": "body",
      "text": "Aspect ratio: 4:1",
      "hash": "6626f41bfa6b"
    },
    "body:0038": {
      "field": "body",
      "text": "On mobile: crops to approx. 3:1",
      "hash": "d5cba55d43c8"
    },
    "body:0039": {
      "field": "body",
      "text": "Input (idea) card",
      "hash": "30d73c11ee60"
    },
    "body:0040": {
      "field": "body",
      "text": "Dimensions: 1024 × 1024 px",
      "hash": "72065198ee57"
    },
    "body:0041": {
      "field": "body",
      "text": "Aspect ratio: 1:1",
      "hash": "3967b55f37e2"
    },
    "body:0042": {
      "field": "body",
      "text": "On mobile: crops to 2:1 or 3:1",
      "hash": "2339b9637627"
    },
    "body:0043": {
      "field": "body",
      "text": "Logo",
      "hash": "d707dc2f1936"
    },
    "body:0044": {
      "field": "body",
      "text": "Minimum height: 48px",
      "hash": "8d23add066a4"
    },
    "body:0045": {
      "field": "body",
      "text": "Ratio: 2:1",
      "hash": "df4882f38b85"
    },
    "body:0046": {
      "field": "body",
      "text": "Displayed in the top-left corner of the navigation menu",
      "hash": "3c712c1969f4"
    },
    "body:0047": {
      "field": "body",
      "text": "Proposal card",
      "hash": "888bbbca43f0"
    },
    "body:0048": {
      "field": "body",
      "text": "Dimensions: 1000 × 500 px",
      "hash": "d1dd533fa975"
    },
    "body:0049": {
      "field": "body",
      "text": "Ratio: 2:1",
      "hash": "df4882f38b85"
    },
    "body:0050": {
      "field": "body",
      "text": "Displayed on the proposal overview page",
      "hash": "15c3b6f45055"
    },
    "body:0051": {
      "field": "body",
      "text": "Event card",
      "hash": "35eeef5f086d"
    },
    "body:0052": {
      "field": "body",
      "text": "Dimensions: 1800 × 600 px",
      "hash": "033ca17aa714"
    },
    "body:0053": {
      "field": "body",
      "text": "Ratio: 3:1",
      "hash": "c1d481a842d4"
    },
    "body:0054": {
      "field": "body",
      "text": "Displayed at the bottom of project pages and under the Events tab",
      "hash": "bc47bdb0eb9d"
    },
    "body:0055": {
      "field": "body",
      "text": "In-text images",
      "hash": "6dc907a2e033"
    },
    "body:0056": {
      "field": "body",
      "text": "Can be added in project/phase descriptions or surveys",
      "hash": "3a5ee902f3b3"
    },
    "body:0057": {
      "field": "body",
      "text": "Titles are mandatory for accessibility",
      "hash": "6e0e59499ef5"
    },
    "body:0058": {
      "field": "body",
      "text": "Resizable in regular text fields but not in content builders",
      "hash": "d175a7b37a3e"
    },
    "body:0059": {
      "field": "body",
      "text": "What are the different homepage banner display options?",
      "hash": "7d7d888cd815"
    },
    "body:0060": {
      "field": "body",
      "text": "You can choose between 3 layout options for your homepage banner:",
      "hash": "4303fde1c943"
    },
    "body:0061": {
      "field": "body",
      "text": "Full-width banner",
      "hash": "03d68fb93222"
    },
    "body:0062": {
      "field": "body",
      "text": "Offers the most visual impact",
      "hash": "766c8078e212"
    },
    "body:0063": {
      "field": "body",
      "text": "Crops the image the most",
      "hash": "4e68f616739f"
    },
    "body:0064": {
      "field": "body",
      "text": "Best for abstract, decorative visuals without text",
      "hash": "5ae1e71f6480"
    },
    "body:0065": {
      "field": "body",
      "text": "Two-row banner",
      "hash": "7406bc93ea32"
    },
    "body:0066": {
      "field": "body",
      "text": "Title, subtitle, and button appear below the image",
      "hash": "df6ca9716db8"
    },
    "body:0067": {
      "field": "body",
      "text": "Useful if your image doesn’t pair well with overlaid text",
      "hash": "6c9f558d3aca"
    },
    "body:0068": {
      "field": "body",
      "text": "Fixed-ratio banner",
      "hash": "d381f6f03798"
    },
    "body:0069": {
      "field": "body",
      "text": "Recommended ratio: 3:1",
      "hash": "7be83655d641"
    },
    "body:0070": {
      "field": "body",
      "text": "Maintains a consistent display area",
      "hash": "933f6cf4421b"
    },
    "body:0071": {
      "field": "body",
      "text": "When uploading, you can drag the image to choose which part stays visible",
      "hash": "fd45574645aa"
    },
    "body:0072": {
      "field": "body",
      "text": "⚠️ Regardless of layout, avoid using text inside the image as it may get cropped on smaller screens.",
      "hash": "ca2131ccae73"
    },
    "body:0073": {
      "field": "body",
      "text": "How to resize images on the platform?",
      "hash": "4d086fec44c3"
    },
    "body:0074": {
      "field": "body",
      "text": "In regular text boxes, you can resize by dragging the image corners.",
      "hash": "a0fecb9cb93a"
    },
    "body:0075": {
      "field": "body",
      "text": "In content builder areas (e.g., homepage builder, project description), resizing is not possible this way, images retain their original size. There is a trick you an use if you need to resize an image inside the content builder. You can use columns within columns to make the image smaller.",
      "hash": "713db93fb5a6"
    },
    "body:0076": {
      "field": "body",
      "text": "💡 Visually reduce image sizes in the content builder by using columns within columns.",
      "hash": "cfeaf91ffbac"
    }
  }
}